          "vectorStoreRetriever": "{{chroma_0.data.instance}}",
          "memory": "",
          "returnSourceDocuments": true,
          "rephrasePrompt": "Given the following conversation and a follow up question, rephrase the follow up question to be a standalone question.\n\nChat History:\n{chat_history}\nFollow Up Input: {question}\nStandalone Question:",
          "responsePrompt": "You are a helpful AI assistant that answers questions by understanding the uploaded PDF context.\n\nInstructions:\n\n* Carefully analyze the retrieved PDF context before answering.\n* Answer mainly using the information from the PDF.\n* Explain the answer in simple, natural, human-like language.\n* Do not generate unrelated information.\n* Do not rely heavily on outside knowledge.\n* If useful, you may add small supporting insights or trivia, but only if they are relevant to the PDF context.\n* Focus on clarity, understanding, and conversational explanation.\n* Avoid robotic phrases like \"According to the PDF\".\n* Do not mention document IDs or chunk IDs.\n* If the PDF does not contain enough information, say so politely.\n\nRetrieved Context:\n{context}\n\nUser Question:\n{question}\n\nGive a natural, easy-to-understand answer:\n",
          "inputModeration": ""
        },
