# ────────────────────────────────────────────────────
# FilmInsight Environment Variables
# Copy to .env and fill in your values
# ────────────────────────────────────────────────────

# ── Flowise ──────────────────────────────────────────
# Your Flowise server URL
FLOWISE_URL=http://localhost:9000

# Your chatflow ID from the Flowise canvas URL
# Example: http://localhost:9000/canvas/06f35a86-dc89-4e3f-b284-380f894ab783
#                                              ↑ this is your CHATFLOW_ID
FLOWISE_CHATFLOW_ID=06f35a86-dc89-4e3f-b284-380f894ab783

# Optional: API key if Flowise authentication is enabled
FLOWISE_API_KEY=

# ── Flowise Admin ─────────────────────────────────────
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=filminsight2025

# ── Frontend ──────────────────────────────────────────
# API base URL (use /api for Nginx proxy, or http://localhost:8000 for direct)
VITE_API_URL=/api
