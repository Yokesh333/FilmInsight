# ────────────────────────────────────────────────────
# FilmInsight Environment Variables
# Copy to .env and fill in your values
# ────────────────────────────────────────────────────

# ── Flowise ──────────────────────────────────────────
# Your Flowise server URL
FLOWISE_URL=http://localhost:9000

# Your chatflow ID from the Flowise canvas URL
# Example: http://localhost:9000/canvas/06f35a86-dc89-4e3f-b284-380f894ab783
#                                              ↑ this is your CHATFLOW_ID
FLOWISE_CHATFLOW_ID=06f35a86-dc89-4e3f-b284-380f894ab783

# Optional: API key if Flowise authentication is enabled
FLOWISE_API_KEY=xxxxxxxxxxxxxxxx
FLOWISE_API_URL=https://cloud.flowiseai.com/api/v1/prediction/......

# ── Flowise Admin ─────────────────────────────────────
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=filminsight2025

# ── Frontend ──────────────────────────────────────────
# API base URL (use /api for Nginx proxy, or http://localhost:8000 for direct)
VITE_API_URL=/api

# ── Knowledge Base Paths ──────────────────────────────
# Override only if your layout differs from the defaults.
# In Docker these are set by docker-compose.yml automatically.
# MOVIE_SCRIPTS_DIR=/opt/filminsight/movie_scripts
# CHROMA_DB_DIR=/opt/filminsight/chroma_db
# CHROMA_COLLECTION_NAME=filminsight_scripts

# ── Metadata API Keys (used by ingestion pipeline) ────
# Sign up free at https://www.themoviedb.org/
TMDB_API_KEY=239967a7888fc811609db5aa3b554431

# Sign up free at https://www.omdbapi.com/
OMDB_API_KEY=72bf0fb9

# ── Supabase ──────────────────────────────────────────
# Supabase project URL and Keys
SUPABASE_URL=https://abcdefghijk.supabase.co
SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Embedding Model ───────────────────────────────────
# Change if you want a different HuggingFace sentence-transformer
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DEVICE=cpu

