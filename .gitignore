# ══════════════════════════════════════════════════════════════════
#  FilmInsight — .gitignore
#  Production-grade exclusions for GitHub
# ══════════════════════════════════════════════════════════════════

# ── Movie data (copyright / large binary) ─────────────────────────
movie_scripts/
movie scripts/

# ── Vector database (auto-generated, can be large) ────────────────
chroma_db/
docker/chroma_data/

# ── Ingestion logs ────────────────────────────────────────────────
logs/
ingestion/logs/
*.log

# ── Python bytecode & caches ──────────────────────────────────────
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.pycache
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ──────────────────────────────────────────
.venv/
venv/
env/
backend/.venv/
ingestion/.venv/

# ── Environment files (secrets) ───────────────────────────────────
.env
*.env
!.env.example

# ── Node / Frontend ───────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build artefacts ───────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── IDE & editor files ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
*.sublime-workspace
*.sublime-project

# ── OS-generated files ────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Docker volumes managed outside repo ──────────────────────────
docker/flowise_data/

# ── Temporary / scratch files ─────────────────────────────────────
*.tmp
*.bak
*.swp
*.orig
